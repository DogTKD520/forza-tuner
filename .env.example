# =============================================================================
# Forza Tuner — Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env directly.
# =============================================================================

# --------------- Server ---------------
HOST=0.0.0.0
PORT=8000

# --------------- UDP Telemetry Listener ---------------
UDP_HOST=0.0.0.0
UDP_PORT=5300

# --------------- Default Game Profile ---------------
# Options: FM (Forza Motorsport) | FH (Forza Horizon)
DEFAULT_GAME=FM

# --------------- Multi-Tenancy ---------------
# In MVP mode all data is scoped to this user. Replace with identity-header
# value (e.g. Cloudflare Access CF-Access-Authenticated-User-Email) later.
DEFAULT_USER_ID=local_admin

# --------------- Database ---------------
# Relative path is resolved inside the container's /app working directory.
DATABASE_URL=sqlite:///./data/forza_tuner.db

# --------------- WebSocket Live Feed ---------------
# Throttle rate for live telemetry pushes to connected browser clients.
WEBSOCKET_FPS=15

# --------------- AI / LLM Strategy ---------------
# Set USE_LLM=True to swap MathBaselineAnalyzer for OllamaAnalyzer.
USE_LLM=False
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
